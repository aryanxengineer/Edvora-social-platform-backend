{
  "name": "backend",
  "version": "1.0.0",
  "description": "Social media backend (TypeScript + ESM)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "verbose": true
  },
  "_moduleAliases": {
    "@common": "dist/common",
    "@config": "dist/config",
    "@constants": "dist/constants",
    "@jobs": "dist/jobs",
    "@libs": "dist/libs",
    "@logger": "dist/logger",
    "@middlewares": "dist/middlewares",
    "@modules": "dist/modules",
    "@queues": "dist/queues",
    "@routes": "dist/routes",
    "@types": "dist/types"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.8.0",
    "compression": "^1.7.4",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "express-winston": "^4.2.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.2.3",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.1",
    "multer": "^2.0.2",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "tsup": "^8.5.1",
    "winston": "^3.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
